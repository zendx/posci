# POSCI - Environment Configuration
# Copy this file to .env and update with your local/production values

# Application Settings
APP_NAME=POSCI
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/posci/

# Database Configuration
DB_CONNECTION=mysqli
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=posci
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8
DB_COLLATION=utf8_general_ci

# Cache Settings
CACHE_DRIVER=file
CACHE_PATH=application/cache

# Session Settings
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Authentication
AUTH_TIMEOUT=3600

# Timezone
APP_TIMEZONE=UTC

# Log Settings
LOG_PATH=application/logs

# Email Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@posci.local
MAIL_FROM_NAME="POSCI"

# Upload Configuration
UPLOAD_PATH=public/uploads
MAX_UPLOAD_SIZE=5242880

# Security
ENCRYPTION_KEY=your_encryption_key_here
CSRF_TOKEN_NAME=csrf_token_name
CSRF_COOKIE_NAME=csrf_cookie_name
